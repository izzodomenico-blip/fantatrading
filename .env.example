# Ambiente
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173

# Backend / Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/fantatrading_dev"

# Auth JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Simulazione
SIMULATION_SEED=42
SIMULATION_NUM_RUNS=1000
LOG_LEVEL=info

# Output
REPORTS_DIR=./reports
