{
  "name": "fantatrading-engine",
  "version": "0.1.0",
  "description": "Motore matematico e simulativo per verificare la sostenibilità economica del regolamento FantaTrading",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "simulate": "ts-node scripts/runSimulation.ts",
    "phase2": "ts-node --project tsconfig.scripts.json scripts/run-phase2.ts",
    "phase3": "ts-node --project tsconfig.scripts.json scripts/run-rule-comparison.ts",
    "phase3:sensitivity": "ts-node --project tsconfig.scripts.json scripts/run-sensitivity.ts",
    "phase3:optimize": "ts-node --project tsconfig.scripts.json scripts/run-optimizer.ts",
    "phase3:prize-table": "ts-node --project tsconfig.scripts.json scripts/run-prize-table-optimizer.ts",
    "phase4:price-model": "ts-node --project tsconfig.scripts.json scripts/run-price-model-analysis.ts",
    "master": "ts-node --project tsconfig.scripts.json scripts/run-master-report.ts",
    "import:real-quotes": "ts-node --project tsconfig.scripts.json scripts/import-real-quotes.ts",
    "analyze:real-quotes": "ts-node --project tsconfig.scripts.json scripts/analyze-real-quotes.ts",
    "import:real-votes": "ts-node --project tsconfig.scripts.json scripts/import-real-votes.ts",
    "analyze:real-votes": "ts-node --project tsconfig.scripts.json scripts/analyze-real-votes.ts",
    "historical:backtest": "ts-node --project tsconfig.scripts.json scripts/run-historical-backtest.ts",
    "historical:strategy-backtest": "ts-node --project tsconfig.scripts.json scripts/run-historical-strategy-backtest.ts",
    "historical:full-rules-backtest": "ts-node --project tsconfig.scripts.json scripts/run-historical-full-rules-backtest.ts",
    "full-rules:stress-test": "ts-node --project tsconfig.scripts.json scripts/run-full-rules-stress-test.ts",
    "synthetic:quote-calibration": "ts-node --project tsconfig.scripts.json scripts/run-synthetic-quote-calibration.ts",
    "synthetic:quote-study": "ts-node --project tsconfig.scripts.json scripts/run-synthetic-quote-model-study.ts",
    "synthetic:quote-deep-optimizer": "ts-node --project tsconfig.scripts.json scripts/run-synthetic-quote-deep-optimizer.ts",
    "synthetic:quote-operational-model": "ts-node --project tsconfig.scripts.json scripts/run-synthetic-quote-operational-model.ts",
    "intraseason:backtest": "ts-node --project tsconfig.scripts.json scripts/run-intraseason-trading-backtest.ts",
    "intraseason:fee-comparison": "ts-node --project tsconfig.scripts.json scripts/run-intraseason-fee-comparison.ts",
    "commission:revenue-simulation": "ts-node --project tsconfig.scripts.json scripts/run-commission-revenue-model-simulation.ts",
    "web:install": "npm install --prefix app/web",
    "web:dev": "npm run dev --prefix app/web",
    "web:build": "npm run build --prefix app/web",
    "backend:install": "npm install --prefix apps/backend",
    "backend:dev": "npm run start:dev --prefix apps/backend",
    "backend:build": "npm run build --prefix apps/backend",
    "backend:test": "npm run test --prefix apps/backend",
    "prisma:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:dev": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
